<form class="{{cssClass}} v-sheet action-first npc {{#if vitruvium.isEditing}}is-editing{{/if}}" autocomplete="off">

  {{!-- ZONE A: HEADER --}}
  <header class="v-header">
    <div class="v-header__main">
      <div class="v-header__portrait">
        <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
        <button type="button" class="v-edit-toggle {{#if vitruvium.isEditing}}is-active{{/if}}"
          data-action="toggle-edit" title="Переключить режим редактирования">
          <i class="fas fa-edit"></i>
        </button>
      </div>

      <div class="v-header__info">
        <div class="v-meta">
          {{#if vitruvium.isEditing}}
          <input name="name" type="text" value="{{actor.name}}" class="v-name-input" />
          <span class="v-meta__sep">/</span>
          <input name="system.attributes.level" type="number" value="{{vitruvium.header.level}}"
            class="v-level-input" />
          {{else}}
          <span class="v-meta__name">{{actor.name}}</span>
          <span class="v-meta__sep">/</span>
          <span class="v-meta__level">РГ {{vitruvium.header.level}}</span>
          {{/if}}
        </div>

        <div class="v-resource-bars">
          <div class="v-resource-bar hp" title="Очки здоровья">
            <div class="v-resource-bar__fill" style="width: {{vitruvium.header.hp.pct}}%"></div>
            <div class="v-resource-bar__label">
              {{#if vitruvium.isEditing}}
              <input name="system.attributes.hp.value" type="number" value="{{vitruvium.header.hp.value}}" /> /
              <input name="system.attributes.hp.max" type="number" value="{{vitruvium.header.hp.max}}" />
              {{else}}
              {{vitruvium.header.hp.value}} / {{vitruvium.header.hp.max}} ОЗ
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      <div class="v-header__actions">
        <button type="button" class="v-mini" data-action="create-item" data-type="ability" title="Добавить способность"><i
            class="fas fa-magic"></i></button>
        <button type="button" class="v-mini" data-action="create-item" data-type="item" title="Добавить предмет"><i
            class="fas fa-plus"></i></button>
      </div>
    </div>

    <div class="v-header__lower">
      <div class="v-active-effects">
        {{#each vitruvium.header.effects as |effect|}}
        <div class="v-effect-icon" data-item-id="{{effect.id}}" data-action="item-chat"
          title="{{effect.name}}: {{effect.description}}">
          <img src="{{effect.img}}" />
        </div>
        {{/each}}
      </div>
    </div>
  </header>

  <div class="v-sheet__body">
    {{!-- ZONE B: CENTRAL --}}
    <main class="v-main">
      <nav class="v-tabs">
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'actions')}}is-active{{/if}}" data-tab="actions">Действия</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'inventory')}}is-active{{/if}}"
          data-tab="inventory">Инвентарь</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'effects')}}is-active{{/if}}" data-tab="effects">Эффекты</a>
      </nav>

      <section class="v-tab-content">
        {{#if (eq vitruvium.activeTab 'actions')}}
        <div class="v-actions-grid">
          <div class="v-section">
            <div class="v-section__header">Атаки</div>
            <div class="v-action-cards">
              {{#each vitruvium.tabs.actions.weapons as |w|}}
              <div class="v-action-card weapon">
                <img src="{{w.img}}" data-action="use" data-item-id="{{w.id}}" />
                <div class="v-action-card__info">
                  <span class="v-name">{{w.name}}</span>
                  <span class="v-dmg">+{{w.damage}} УРН</span>
                </div>
                <button type="button" class="v-roll-btn" data-action="attack" data-item-id="{{w.id}}">
                  <i class="fas fa-dice-d20"></i>
                </button>
              </div>
              {{/each}}
            </div>
          </div>

          <div class="v-section">
            <div class="v-section__header">Способности</div>
            <div class="v-list">
              {{#each vitruvium.tabs.actions.abilities as |a|}}
              <div class="v-list-item">
                <img src="{{a.img}}" data-action="use" data-item-id="{{a.id}}" />
                <div class="v-item-info">
                  <div class="v-item-name">{{a.name}}</div>
                  <div class="v-item-meta">Цена: {{a.cost}}</div>
                </div>
                <div class="v-item-controls">
                  <button type="button" class="v-icon-btn {{#if a.active}}is-active{{/if}}" data-action="toggle-active"
                    data-item-id="{{a.id}}">
                    <i class="fas fa-bolt"></i>
                  </button>
                </div>
              </div>
              {{/each}}
            </div>
          </div>

          <div class="v-section">
            <div class="v-section__header">Быстрые броски</div>
            <div class="v-quick-rolls">
              {{#each vitruvium.tabs.actions.quickRolls as |attr|}}
              <button type="button" class="v-quick-roll" data-action="roll-attr" data-attr="{{attr.key}}">
                <i class="fas {{attr.icon}}"></i>
                <span>{{attr.label}}</span>
              </button>
              {{/each}}
            </div>
          </div>
        </div>

        {{else if (eq vitruvium.activeTab 'inventory')}}
        <div class="v-groups">
          {{#each vitruvium.tabs.inventory.groups as |group label|}}
          <div class="v-group">
            <div class="v-group__header">{{label}}</div>
            <div class="v-list">
              {{#each group as |i|}}
              <div class="v-list-item">
                <img src="{{i.img}}" data-action="use" data-item-id="{{i.id}}" />
                <div class="v-item-info">
                  <div class="v-item-name">{{i.name}}</div>
                </div>
                <div class="v-item-controls">
                  <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{i.id}}"><i
                      class="fas fa-edit"></i></button>
                  <button type="button" class="v-icon-btn is-danger" data-action="delete-item"
                    data-item-id="{{i.id}}"><i class="fas fa-trash"></i></button>
                </div>
              </div>
              {{/each}}
            </div>
          </div>
          {{/each}}
        </div>

        {{else if (eq vitruvium.activeTab 'effects')}}
        <div class="v-section">
          <div class="v-section__header">
            <span>Состояния и эффекты</span>
            <button type="button" class="v-mini" data-action="create-item" data-type="state"><i
                class="fas fa-plus"></i></button>
          </div>
          <div class="v-list">
            {{#each vitruvium.tabs.effects.all as |e|}}
            <div class="v-list-item">
              <img src="{{e.img}}" />
              <div class="v-item-info">
                <div class="v-item-name">{{e.name}}</div>
                <div class="v-item-meta">Длительность: {{e.duration}}</div>
              </div>
              <div class="v-item-controls">
                <button type="button" class="v-icon-btn {{#if e.active}}is-active{{/if}}" data-action="toggle-active"
                  data-item-id="{{e.id}}">
                  <i class="fas fa-toggle-on"></i>
                </button>
                <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{e.id}}"><i
                    class="fas fa-trash"></i></button>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/if}}
      </section>
    </main>

    {{!-- ZONE C: SIDEBAR --}}
    <aside class="v-sidebar">
      <div class="v-attr-grid">
        {{#each vitruvium.sidebar.attributes as |attr|}}
        <div class="v-attr-card">
          <div class="v-attr-card__label">{{attr.label}}</div>
          <div class="v-attr-card__value">
            {{#if ../vitruvium.isEditing}}
            <input name="system.attributes.{{attr.key}}" type="number" value="{{attr.value}}" />
            {{else}}
            {{attr.value}}
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>

      <div class="v-derived-stats">
        <div class="v-stat">
          <label>Защита</label>
          {{#if vitruvium.isEditing}}
          <input name="system.attributes.armor.value" type="number" value="{{vitruvium.sidebar.derived.armor}}" />
          {{else}}
          <span>{{vitruvium.sidebar.derived.armor}}</span>
          {{/if}}
        </div>
        <div class="v-stat">
          <label>Скорость</label>
          {{#if vitruvium.isEditing}}
          <input name="system.attributes.speed.value" type="number" value="{{vitruvium.sidebar.derived.speed}}" />
          {{else}}
          <span>{{vitruvium.sidebar.derived.speed}}</span>
          {{/if}}
        </div>
      </div>
    </aside>
  </div>
</form>