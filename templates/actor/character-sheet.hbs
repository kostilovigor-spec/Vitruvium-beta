<form class="{{cssClass}} v-sheet action-first {{#if vitruvium.isEditing}}is-editing{{/if}}" autocomplete="off">

  {{!-- ZONE A: HEADER --}}
  <header class="v-header">
    <div class="v-header__main">
      <div class="v-header__portrait">
        <img src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
        <button type="button" class="v-edit-toggle {{#if vitruvium.isEditing}}is-active{{/if}}"
          data-action="toggle-edit" title="Переключить режим редактирования">
          <i class="fas fa-edit"></i>
        </button>
      </div>

      <div class="v-header__info">
        <div class="v-meta">
          {{#if vitruvium.isEditing}}
          <input name="name" type="text" value="{{actor.name}}" class="v-name-input" />
          <span class="v-meta__sep">/</span>
          <input name="system.attributes.level" type="number" value="{{vitruvium.header.level}}"
            class="v-level-input" />
          {{else}}
          <span class="v-meta__name">{{actor.name}}</span>
          <span class="v-meta__sep">/</span>
          <span class="v-meta__level">Уровень {{vitruvium.header.level}}</span>
          {{/if}}
        </div>

        <div class="v-resource-bars">
          <div class="v-resource-bar hp" title="Очки здоровья">
            <div class="v-resource-bar__fill" style="width: {{vitruvium.header.hp.pct}}%"></div>
            <div class="v-resource-bar__label">
              {{#if vitruvium.isEditing}}
              <input name="system.attributes.hp.value" type="number" value="{{vitruvium.header.hp.value}}" /> /
              <input name="system.attributes.hp.max" type="number" value="{{vitruvium.header.hp.max}}" />
              {{else}}
              {{vitruvium.header.hp.value}} / {{vitruvium.header.hp.max}} ОЗ
              {{/if}}
            </div>
          </div>
          <div class="v-resource-bar inspiration" title="Вдохновение">
            <div class="v-resource-bar__fill" style="width: {{vitruvium.header.inspiration.pct}}%"></div>
            <div class="v-resource-bar__label">{{vitruvium.header.inspiration.value}} /
              {{vitruvium.header.inspiration.max}} ВДОХН</div>
          </div>
        </div>
      </div>

      <div class="v-header__actions">
        <button type="button" class="v-btn v-btn--primary" data-action="long-rest" title="Долгий отдых">
          <i class="fas fa-bed"></i> <span>Отдых</span>
        </button>
      </div>
    </div>

    <div class="v-header__lower">
      <div class="v-active-effects">
        {{#each vitruvium.header.effects as |effect|}}
        <div class="v-effect-icon" data-item-id="{{effect.id}}" data-action="item-chat"
          title="{{effect.name}}: {{effect.description}}">
          <img src="{{effect.img}}" />
        </div>
        {{/each}}
      </div>
      <div class="v-coins">
        <div class="v-coin bronze">
          <input name="system.coins.bronze" type="number" value="{{vitruvium.sidebar.coins.bronze}}" />
          <span>Бронза</span>
        </div>
        <div class="v-coin silver">
          <input name="system.coins.silver" type="number" value="{{vitruvium.sidebar.coins.silver}}" />
          <span>Серебро</span>
        </div>
        <div class="v-coin gold">
          <input name="system.coins.gold" type="number" value="{{vitruvium.sidebar.coins.gold}}" />
          <span>Золото</span>
        </div>
      </div>
    </div>
  </header>

  <div class="v-sheet__body">
    {{!-- ZONE B: CENTRAL (Action Panels) --}}
    <main class="v-main">
      <nav class="v-tabs">
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'actions')}}is-active{{/if}}" data-tab="actions">Действия</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'inventory')}}is-active{{/if}}"
          data-tab="inventory">Инвентарь</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'abilities')}}is-active{{/if}}"
          data-tab="abilities">Способности</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'skills')}}is-active{{/if}}" data-tab="skills">Навыки</a>
        <a class="v-tab-link {{#if (eq vitruvium.activeTab 'effects')}}is-active{{/if}}" data-tab="effects">Эффекты</a>
      </nav>

      <section class="v-tab-content">
        {{#if (eq vitruvium.activeTab 'actions')}}
        <div class="v-actions-grid">
          <div class="v-section">
            <div class="v-section__header">Атака</div>
            <div class="v-action-cards">
              {{#each vitruvium.tabs.actions.weapons as |w|}}
              <div class="v-action-card weapon">
                <img src="{{w.img}}" data-action="use" data-item-id="{{w.id}}" />
                <div class="v-action-card__info">
                  <span class="v-name">{{w.name}}</span>
                  <span class="v-dmg">+{{w.damage}} Урон</span>
                </div>
                <div class="v-action-card__controls">
                  <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{w.id}}" title="Редактировать">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{w.id}}" title="Удалить">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
                <button type="button" class="v-roll-btn" data-action="attack" data-item-id="{{w.id}}">
                  <i class="fas fa-dice-d20"></i>
                </button>
              </div>
              {{/each}}
            </div>
          </div>

          <div class="v-section">
            <div class="v-section__header">Активные способности</div>
            <div class="v-action-cards">
              {{#each vitruvium.tabs.actions.abilities as |a|}}
              <div class="v-action-card ability">
                <img src="{{a.img}}" data-action="use-ability" data-item-id="{{a.id}}" />
                <div class="v-action-card__info">
                  <span class="v-name">{{a.name}}</span>
                  <span class="v-cost">Цена: {{a.cost}}</span>
                </div>
                <div class="v-action-card__controls">
                  <button type="button" class="v-icon-btn {{#if a.active}}is-active{{/if}}" data-action="toggle-active" data-item-id="{{a.id}}" title="Активно">
                    <i class="fas fa-power-off"></i>
                  </button>
                  <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{a.id}}" title="Редактировать">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{a.id}}" title="Удалить">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
                <button type="button" class="v-roll-btn" data-action="use-ability" data-item-id="{{a.id}}">
                  <i class="fas fa-magic"></i>
                </button>
              </div>
              {{/each}}
            </div>
          </div>

          <div class="v-section">
            <div class="v-section__header">Глобальные проверки</div>
            <div class="v-quick-rolls">
              <button type="button" class="v-quick-roll" data-action="roll-luck">
                <i class="fas fa-clover"></i>
                <span>Бросок на удачу</span>
              </button>
              <button type="button" class="v-quick-roll" data-action="roll-bonus-dice">
                <i class="fas fa-dice"></i>
                <span>Бонусный кубик</span>
              </button>
            </div>
          </div>
        </div>

        {{else if (eq vitruvium.activeTab 'inventory')}}
        <div class="v-groups">
          {{#each vitruvium.tabs.inventory.groups as |group|}}
          <div class="v-group {{#if group.isCollapsed}}is-collapsed{{/if}}">
            <div class="v-group__header">
              <div class="v-group__header-left" data-action="toggle-group" data-group-id="item-{{group.key}}">
                <i class="fas {{#if group.isCollapsed}}fa-chevron-right{{else}}fa-chevron-down{{/if}}"></i>
                {{group.label}}
              </div>
              <button type="button" class="v-add-item-btn" data-action="add-inventory-item" data-type="{{group.key}}" title="Добавить предмет">
                <i class="fas fa-plus"></i>
              </button>
            </div>
            {{#unless group.isCollapsed}}
            <div class="v-list">
              {{#each group.items as |i|}}
              <div class="v-list-item">
                <img src="{{i.img}}" data-action="use" data-item-id="{{i.id}}" />
                <div class="v-item-info">
                  <div class="v-item-name">{{i.name}}</div>
                  <div class="v-item-meta">Кол-во: {{i.system.quantity}} | Цена: {{i.system.price}}</div>
                </div>
                <div class="v-item-controls">
                  <button type="button" class="v-icon-btn {{#if i.system.equipped}}is-active{{/if}}"
                    data-action="toggle-equip" data-item-id="{{i.id}}" title="Экипировать">
                    <i class="fas fa-shield-alt"></i>
                  </button>
                  <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{i.id}}" title="Редактировать">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="v-icon-btn is-danger" data-action="delete-item"
                    data-item-id="{{i.id}}" title="Удалить"><i class="fas fa-trash"></i></button>
                </div>
              </div>
              {{/each}}
            </div>
            {{/unless}}
          </div>
          {{/each}}
        </div>

        {{else if (eq vitruvium.activeTab 'abilities')}}
        <div class="v-groups">
          {{#each vitruvium.tabs.abilities.groups as |group|}}
          <div class="v-group {{#if group.isCollapsed}}is-collapsed{{/if}}">
            <div class="v-group__header" data-action="toggle-group" data-group-id="ability-{{group.key}}">
              <i class="fas {{#if group.isCollapsed}}fa-chevron-right{{else}}fa-chevron-down{{/if}}"></i>
              {{group.label}}
            </div>
            {{#unless group.isCollapsed}}
            <div class="v-list">
              {{#each group.items as |a|}}
              <div class="v-list-item">
                <img src="{{a.img}}" data-action="use" data-item-id="{{a.id}}" />
                <div class="v-item-info">
                  <div class="v-item-name">{{a.name}}</div>
                  <div class="v-item-meta">Цена: {{a.system.cost}} | Действия: {{a.system.actions}}</div>
                </div>
                <div class="v-item-controls">
                  <button type="button" class="v-icon-btn {{#if a.system.active}}is-active{{/if}}"
                    data-action="toggle-active" data-item-id="{{a.id}}" title="Активно">
                    <i class="fas fa-power-off"></i>
                  </button>
                  <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{a.id}}" title="Редактировать">
                    <i class="fas fa-edit"></i>
                  </button>
                  <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{a.id}}" title="Удалить">
                    <i class="fas fa-trash"></i>
                  </button>
                </div>
              </div>
              {{/each}}
            </div>
            {{/unless}}
          </div>
          {{/each}}
        </div>

        {{else if (eq vitruvium.activeTab 'skills')}}
        <div class="v-list">
          {{#each vitruvium.tabs.skills.all as |s|}}
          <div class="v-list-item">
            <img src="{{s.img}}" data-action="item-chat" data-item-id="{{s.id}}" />
            <div class="v-item-info">
              <div class="v-item-name">{{s.name}}</div>
            </div>
            <div class="v-item-controls">
              <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{s.id}}" title="Редактировать">
                <i class="fas fa-edit"></i>
              </button>
              <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{s.id}}" title="Удалить">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </div>
          {{/each}}
        </div>

        {{else if (eq vitruvium.activeTab 'effects')}}
        <div class="v-section">
          <div class="v-section__header">
            <span>Активные эффекты</span>
            <button type="button" class="v-mini" data-action="create-item" data-type="state"><i
                class="fas fa-plus"></i></button>
          </div>
          <div class="v-list">
            {{#each vitruvium.tabs.effects.all as |e|}}
            <div class="v-list-item">
              <img src="{{e.img}}" />
              <div class="v-item-info">
                <div class="v-item-name">{{e.name}}</div>
                <div class="v-item-meta">Длительность: {{e.duration}}</div>
              </div>
              <div class="v-item-controls">
                <button type="button" class="v-icon-btn {{#if e.active}}is-active{{/if}}" data-action="toggle-active"
                  data-item-id="{{e.id}}" title="Активно">
                  <i class="fas fa-toggle-on"></i>
                </button>
                <button type="button" class="v-icon-btn" data-action="edit-item" data-item-id="{{e.id}}" title="Редактировать">
                  <i class="fas fa-edit"></i>
                </button>
                <button type="button" class="v-icon-btn is-danger" data-action="delete-item" data-item-id="{{e.id}}" title="Удалить">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/if}}
      </section>
    </main>

    {{!-- ZONE C: SIDEBAR --}}
    <aside class="v-sidebar">
      <div class="v-attr-grid">
        {{#each vitruvium.sidebar.attributes as |attr|}}
        <div class="v-attr-card {{#unless ../vitruvium.isEditing}}rollable{{/unless}}" {{#unless
          ../vitruvium.isEditing}}data-action="roll-attr" data-attr="{{attr.key}}" title="Бросок: {{attr.label}}"
          {{/unless}}>
          <div class="v-attr-card__label">{{attr.label}}</div>
          <div class="v-attr-card__value">
            {{#if ../vitruvium.isEditing}}
            <input name="system.attributes.{{attr.key}}.value" type="number" value="{{attr.value}}" />
            {{else}}
            {{attr.value}}
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>

      <div class="v-derived-stats">
        <div class="v-stat">
          <label>Защита</label>
          <span>{{vitruvium.sidebar.derived.armor}}</span>
        </div>
        <div class="v-stat">
          <label>Скорость</label>
          <span>{{vitruvium.sidebar.derived.speed}}м</span>
        </div>
      </div>
    </aside>
  </div>
</form>