<form class="{{cssClass}} v-sheet v-item" autocomplete="off">

  <header class="v-item__header">
    <div class="v-item__iconbox">
      <img
        class="v-item__icon"
        src="{{item.img}}"
        data-edit="img"
        title="{{item.name}}"
      />
    </div>

    <div class="v-item__headcenter">
      <div class="v-item__namewrap">
        <div class="v-item__field-text v-item__nameview">{{item.name}}</div>
        <input
          class="v-item__field-input v-item__nameinput"
          type="text"
          name="name"
          value="{{item.name}}"
          placeholder="РќР°Р·РІР°РЅРёРµ РїСЂРµРґРјРµС‚Р°"
        />
      </div>

      <div class="v-item__statsrow">
        <label class="v-item__stat">
          <span>РЈСЂРѕРЅ</span>
          <div class="v-item__field-text">{{system.attackBonus}}</div>
          <input
            class="v-item__field-input"
            type="number"
            name="system.attackBonus"
            value="{{system.attackBonus}}"
            data-dtype="Number"
            min="0"
            max="6"
          >
        </label>

        <label class="v-item__stat">
          <span>Р‘СЂРѕРЅСЏ</span>
          <div class="v-item__field-text">{{system.armorBonus}}</div>
          <input
            class="v-item__field-input"
            type="number"
            name="system.armorBonus"
            value="{{system.armorBonus}}"
            data-dtype="Number"
            min="0"
            max="6"
          >
        </label>
      </div>
    </div>

    <div class="v-item__headright">
      <label class="v-item__stat">
        <span>Р¦РµРЅР°</span>
        <div class="v-item__field-text">{{system.price}}</div>
        <input
          class="v-item__field-input"
          type="number"
          name="system.price"
          value="{{system.price}}"
          data-dtype="Number"
          min="0"
        >
      </label>
      <label class="v-item__stat">
        <span>РўРёРї</span>
        <div class="v-item__field-text">
          {{#if (eq system.type "weapon")}}РћСЂСѓР¶РёРµ
          {{else if (eq system.type "equipment")}}РЎРЅР°СЂСЏР¶РµРЅРёРµ
          {{else if (eq system.type "consumables")}}Р Р°СЃС…РѕРґРЅРёРєРё
          {{else if (eq system.type "trinkets")}}Р‘РµР·РґРµР»СѓС€РєРё
          {{else if (eq system.type "tools")}}РРЅСЃС‚СЂСѓРјРµРЅС‚С‹
          {{else if (eq system.type "loot")}}Р”РѕР±С‹С‡Р°
          {{else}}РЎРЅР°СЂСЏР¶РµРЅРёРµ{{/if}}
        </div>
        <select name="system.type" class="v-item__field-input">
          <option value="weapon" {{#if (eq system.type "weapon")}}selected{{/if}}>РћСЂСѓР¶РёРµ</option>
          <option value="equipment" {{#if (eq system.type "equipment")}}selected{{/if}}>РЎРЅР°СЂСЏР¶РµРЅРёРµ</option>
          <option value="consumables" {{#if (eq system.type "consumables")}}selected{{/if}}>Р Р°СЃС…РѕРґРЅРёРєРё</option>
          <option value="trinkets" {{#if (eq system.type "trinkets")}}selected{{/if}}>Р‘РµР·РґРµР»СѓС€РєРё</option>
          <option value="tools" {{#if (eq system.type "tools")}}selected{{/if}}>РРЅСЃС‚СЂСѓРјРµРЅС‚С‹</option>
          <option value="loot" {{#if (eq system.type "loot")}}selected{{/if}}>Р”РѕР±С‹С‡Р°</option>
        </select>
      </label>

      <label class="v-item__stat">
        <span>РљРѕР»-РІРѕ</span>
        <div class="v-item__field-text">{{system.quantity}}</div>
        <input
          class="v-item__field-input"
          type="number"
          name="system.quantity"
          value="{{system.quantity}}"
          data-dtype="Number"
          min="0"
        >
      </label>
    </div>
  </header>

  <section class="v-itemtabs">
    <input
      type="radio"
      id="{{vitruvium.tabIds.desc}}"
      name="{{vitruvium.tabName}}"
      value="desc"
      class="v-itemtabs__toggle"
      {{#if (eq vitruvium.activeTab "desc")}}checked{{/if}}
    />
    <input
      type="radio"
      id="{{vitruvium.tabIds.effects}}"
      name="{{vitruvium.tabName}}"
      value="effects"
      class="v-itemtabs__toggle"
      {{#if (eq vitruvium.activeTab "effects")}}checked{{/if}}
    />

    <div class="v-itemtabs__nav" role="tablist">
      <button
        type="button"
        class="v-item__editbtn"
        data-action="toggle-desc"
        title="Р РµРґР°РєС‚РёСЂРѕРІР°С‚СЊ"
      >
        <i class="fas fa-pen"></i>
      </button>
      <label class="v-itemtabs__tab" for="{{vitruvium.tabIds.desc}}" data-tab="desc" role="tab">РћРїРёСЃР°РЅРёРµ</label>
      <label class="v-itemtabs__tab" for="{{vitruvium.tabIds.effects}}" data-tab="effects" role="tab">Р­С„С„РµРєС‚С‹</label>
    </div>

    <div class="v-itemtabs__content">
      <section class="v-itemtabs__panel v-itemtabs__panel--desc" role="tabpanel">
        <div class="v-item__panel">
          <div class="v-item__deschead">
            <div class="v-h2">РћРїРёСЃР°РЅРёРµ</div>
            <div class="v-line"></div>
          </div>

          <div class="v-item__descview" data-role="desc-view">
            {{#if system.description}}
              <div class="v-item__desccontent">{{{vitruvium.descriptionHTML}}}</div>
            {{else}}
              <div class="v-item__descplaceholder">РћРїРёСЃР°РЅРёРµ РЅРµ Р·Р°РґР°РЅРѕ.</div>
            {{/if}}
          </div>

          <textarea
            class="v-item__descedit"
            name="system.description"
            data-role="desc-edit"
          >{{system.description}}</textarea>

          <div class="v-item__attackattr">
            <label>
              <span>РђС‚Р°РєСѓСЋС‰Р°СЏ С…Р°СЂР°РєС‚РµСЂРёСЃС‚РёРєР°</span>
              <select name="system.attackAttr" class="v-item__select">
                {{#each vitruvium.attackAttrOptions as |opt|}}
                  <option value="{{opt.key}}" {{#if (eq opt.key ../vitruvium.attackAttrDefault)}}selected{{/if}}>{{opt.label}}</option>
                {{/each}}
              </select>
            </label>
          </div>

          <div class="v-item__flags">
            <div class="v-item__flag">Р”Р°С‘С‚ Р±Р»РѕРє: {{#if system.canBlock}}Р”Р°{{else}}РќРµС‚{{/if}}</div>
            <div class="v-item__flag">РќР°РґРµС‚Рѕ: {{#if system.equipped}}Р”Р°{{else}}РќРµС‚{{/if}}</div>
            <div class="v-item__flag">Р©РёС‚: {{#if system.isShield}}Р”Р°{{else}}РќРµС‚{{/if}}</div>
            <div class="v-item__flag">РўСЏР¶С‘Р»С‹Рµ РґРѕСЃРїРµС…Рё: {{#if system.isHeavyArmor}}Р”Р°{{else}}РќРµС‚{{/if}}</div>
          </div>

          <div class="v-item__toggles">
            <label class="v-check">
              <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}}>
              <span>РќР°РґРµС‚Рѕ</span>
            </label>

            <label class="v-check">
              <input type="checkbox" name="system.isShield" {{checked system.isShield}}>
              <span>Р©РёС‚</span>
            </label>

            <label class="v-check">
              <input type="checkbox" name="system.canBlock" {{checked system.canBlock}}>
              <span>Р”Р°С‘С‚ Р±Р»РѕРє</span>
            </label>

            <label class="v-check">
              <input type="checkbox" name="system.isHeavyArmor" {{checked system.isHeavyArmor}}>
              <span>РўСЏР¶С‘Р»С‹Рµ РґРѕСЃРїРµС…Рё</span>
            </label>
          </div>
        </div>
      </section>

      <section class="v-itemtabs__panel v-itemtabs__panel--effects" role="tabpanel">
        <div class="v-item__panel">
          <div class="v-item__effectshead">
            <div class="v-h2">Р­С„С„РµРєС‚С‹</div>
            <div class="v-line"></div>
            <button type="button" class="v-mini" data-action="add-effect">+</button>
          </div>

          <div class="v-effects__rows">
            {{#if vitruvium.effects.length}}
              {{#each vitruvium.effects as |eff|}}
                <div class="v-effects__row">
                  <select class="v-effects__key">
                    {{#each ../vitruvium.effectTargets as |opt|}}
                      <option value="{{opt.key}}" {{#if (eq opt.key eff.effectKey)}}selected{{/if}}>{{opt.label}}</option>
                    {{/each}}
                    {{#each ../vitruvium.overTimeEffectTypes as |opt|}}
                      <option value="{{opt.key}}" {{#if (eq opt.key eff.effectKey)}}selected{{/if}}>{{opt.label}}</option>
                    {{/each}}
                  </select>
                  <select class="v-effects__timing" {{#unless eff.isOverTime}}style="display:none;"{{/unless}}>
                    {{#each ../vitruvium.overTimeTriggerTimings as |timing|}}
                      <option value="{{timing.key}}" {{#if (eq timing.key eff.triggerTiming)}}selected{{/if}}>{{timing.label}}</option>
                    {{/each}}
                  </select>
                  <input type="number" class="v-effects__val" value="{{eff.value}}" step="1" />
                  <button type="button" class="v-mini v-effects__remove" title="РЈРґР°Р»РёС‚СЊ">x</button>
                </div>
              {{/each}}
            {{else}}
              <div class="v-effects__row">
                <select class="v-effects__key">
                  {{#each vitruvium.effectTargets as |opt|}}
                    <option value="{{opt.key}}" {{#if @first}}selected{{/if}}>{{opt.label}}</option>
                  {{/each}}
                  {{#each vitruvium.overTimeEffectTypes as |opt|}}
                    <option value="{{opt.key}}">{{opt.label}}</option>
                  {{/each}}
                </select>
                <select class="v-effects__timing" style="display:none;">
                  {{#each vitruvium.overTimeTriggerTimings as |timing|}}
                    <option value="{{timing.key}}" {{#if @first}}selected{{/if}}>{{timing.label}}</option>
                  {{/each}}
                </select>
                <input type="number" class="v-effects__val" value="0" step="1" />
                <button type="button" class="v-mini v-effects__remove" title="РЈРґР°Р»РёС‚СЊ">x</button>
              </div>
            {{/if}}
          </div>
        </div>
      </section>
    </div>
  </section>

</form>


